// 8.Sort and Reverse

import java.util.Scanner;
import java.util.Arrays;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a string: ");
        String str = sc.nextLine();
        char[] ch = str.toCharArray();
        Arrays.sort(ch);
        StringBuilder sb = new StringBuilder(new String(ch));
        sb.reverse();
        System.out.println("Sorted and Reversed: " + sb);
    }
}
import java.util.Scanner;
import java.util.Arrays;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a string: ");
        String str = sc.nextLine();
        char[] ch = str.toCharArray();
        Arrays.sort(ch);
        String sorted = new String(ch);
        System.out.println("Sorted: " + sorted);
        StringBuilder sb = new StringBuilder(sorted);
        sb.reverse();
        System.out.println("Reversed: " + sb);
    }
}


// 9.Count a vowel in a word or a sentence 
import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        String vowels = "aeiouAEIOU";
        System.out.println("Enter a word or a Sentence: ");
        String str = sc.nextLine();
        int count = 0;
        for (int i = 0; i < str.length(); i++) {
            if (vowels.contains(String.valueOf(str.charAt(i)))) {
                count++;
            }
        }
        System.out.println("Number of vowels: " + count);
    }
}


// 10.Palindrome
import java.util.Scanner;
public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter a string: ");
        String str = sc.nextLine();
        String rev = new StringBuilder(str).reverse().toString();
